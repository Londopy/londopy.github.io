---
import ProjectCard from "./ProjectCard.astro";

interface Project {
  cluster: string;
  name: string;
  tagline: string;
  language: string;
  tags: string[];
  repo: string;
  demo?: string | null;
  page?: string | null;
  featured?: boolean;
  stars?: number;
}

interface Props {
  id: string;
  emoji: string;
  title: string;
  blurb?: string;
  projects: Project[];
}

const { id, emoji, title, blurb, projects } = Astro.props;
---

<section id={id} aria-label={title}>
  <div class="section-header">
    <span class="hash" aria-hidden="true">##</span>
    <h2><span aria-hidden="true">{emoji}</span> {title}</h2>
    <span class="rule" aria-hidden="true"></span>
  </div>
  {blurb && <p class="section-blurb">{blurb}</p>}
  <div class="grid">
    {projects.map((p) => <ProjectCard {...p} />)}
  </div>
</section>
