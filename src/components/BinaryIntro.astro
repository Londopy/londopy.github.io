---
// Hacker-style binary rain that plays for ~2s on first load, then fades to
// reveal the page. Skips on reduced-motion and after the first view per session.
---

<div id="binary-intro" aria-hidden="true">
  <canvas id="binary-canvas"></canvas>
  <div class="scanline"></div>
</div>

<style>
  #binary-intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #06090d;
    overflow: hidden;
    transition: opacity 0.6s ease;
  }

  #binary-intro.done {
    opacity: 0;
    pointer-events: none;
  }

  #binary-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* subtle CRT scanline sweep */
  .scanline {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0) 0px,
      rgba(0, 0, 0, 0) 2px,
      rgba(0, 0, 0, 0.25) 3px
    );
    pointer-events: none;
    mix-blend-mode: multiply;
  }

</style>

<script>
  (() => {
    const overlay = document.getElementById("binary-intro");
    if (!overlay) return;

    // Plays on every homepage load, regardless of motion settings.
    // Anyone can dismiss it instantly by clicking or pressing a key.

    // Lock scroll while the intro plays.
    const prevOverflow = document.documentElement.style.overflow;
    document.documentElement.style.overflow = "hidden";

    const canvas = document.getElementById("binary-canvas");
    const ctx = canvas.getContext("2d");
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    let W, H, cols, drops;
    const FONT = 16;

    function resize() {
      W = canvas.width = Math.floor(window.innerWidth * dpr);
      H = canvas.height = Math.floor(window.innerHeight * dpr);
      canvas.style.width = window.innerWidth + "px";
      canvas.style.height = window.innerHeight + "px";
      cols = Math.floor(W / (FONT * dpr));
      drops = new Array(cols).fill(0).map(() => Math.random() * -40);
    }
    resize();
    window.addEventListener("resize", resize);

    const glyphs = "01";
    const step = FONT * dpr;

    function draw() {
      // fade the previous frame → trailing tails
      ctx.fillStyle = "rgba(6, 9, 13, 0.18)";
      ctx.fillRect(0, 0, W, H);
      ctx.font = `${step}px monospace`;

      for (let i = 0; i < cols; i++) {
        const x = i * step;
        const y = drops[i] * step;
        const ch = glyphs[(Math.random() * glyphs.length) | 0];

        // bright leading character, dimmer trail
        ctx.fillStyle = "#c9ffe4";
        ctx.fillText(ch, x, y);
        ctx.fillStyle = "#45d483";
        ctx.fillText(glyphs[(Math.random() * glyphs.length) | 0], x, y - step);

        if (y > H && Math.random() > 0.975) drops[i] = Math.random() * -20;
        drops[i]++;
      }
    }

    let raf;
    let running = true;
    function loop() {
      if (!running) return;
      draw();
      raf = requestAnimationFrame(loop);
    }
    loop();

    function finish() {
      overlay.classList.add("done");
      running = false;
      cancelAnimationFrame(raf);
      document.documentElement.style.overflow = prevOverflow;
      setTimeout(() => overlay.remove(), 650);
    }

    // Play ~1.9s, then reveal. Let users skip with a tap/key.
    const timer = setTimeout(finish, 3200);
    const skip = () => {
      clearTimeout(timer);
      finish();
    };
    overlay.addEventListener("click", skip, { once: true });
    window.addEventListener("keydown", skip, { once: true });
  })();
</script>
